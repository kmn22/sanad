// Sanad — operational legal/SME dashboard
// Persistent data lives here. UI prefs, timer state, and daily todos
// live in localStorage to keep the home server load minimal.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("lawyer") // lawyer | sme_owner | hr | freelancer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Compliance Tracker — Iqama, CR, employee contracts, licenses
model ComplianceItem {
  id          String   @id @default(cuid())
  title       String
  category    String   // iqama | cr | contract | license | tax | gosi
  entityName  String   // employee name, company name, etc.
  issueDate   DateTime
  expiryDate  DateTime
  status      String   @default("active") // active | expiring | expired | renewed
  notes       String?
  notifyDays  Int      @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Case Kanban — Drafting / Client Review / Filed / Closed
model LegalCase {
  id          String   @id @default(cuid())
  title       String
  clientName  String
  caseType    String   // litigation | contract | consultation | ip | corporate
  stage       String   @default("drafting") // drafting | client_review | filed | closed
  priority    String   @default("normal") // low | normal | high | urgent
  dueDate     DateTime?
  value       Float?   // estimated value / billing amount
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timeEntries TimeEntry[]
}

// Document Lifecycle
model LegalDocument {
  id           String   @id @default(cuid())
  title        String
  docType      String   // nda | employment | non_compete | msa | subcontract | policy
  status       String   @default("draft") // draft | sent | active | expiring | expired
  parties      String
  signedDate   DateTime?
  expiryDate   DateTime?
  caseId       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Tasks — manual and auto-generated from doc lifecycle events
model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?
  status       String   @default("todo") // todo | in_progress | done
  priority     String   @default("normal") // low | normal | high
  dueDate      DateTime?
  relatedDoc   String?  // doc title if auto-generated
  caseId       String?
  autoGen      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Billable hours + focus sessions
model TimeEntry {
  id           String   @id @default(cuid())
  caseId       String?
  description  String
  durationSec  Int
  billable     Boolean  @default(false)
  hourlyRate   Float?
  sessionType  String   @default("focus") // focus | billable | meeting
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  case         LegalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
}

// Daily Brief — micro feed of MoJ/MHRSD updates
model DailyBrief {
  id          String   @id @default(cuid())
  title       String
  summary     String
  source      String   // MoJ | MHRSD | VAT | local_tip
  category    String   // regulation | labor | tax | corporate | ip
  url         String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ===== Student mode tables =====

// Courses / subjects a law student is enrolled in
model Course {
  id          String   @id @default(cuid())
  title       String   // e.g. "النظرية العامة للالتزام"
  code        String?  // course code, e.g. "LAW 301"
  instructor  String?
  semester    String?  // e.g. "الفصل الأول 1447هـ"
  credits     Int?
  color       String   @default("#0F5132") // for visual tagging
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lectures    Lecture[]
  deadlines   AcademicDeadline[]
}

// Lecture notes — one entry per lecture session
model Lecture {
  id          String   @id @default(cuid())
  courseId    String
  title       String   // e.g. "محاضرة 5: أسباب انعدام الأهلية"
  lectureDate DateTime
  topic       String?  // sub-topic covered
  notes       String   // markdown / rich text
  attachments String?  // comma-separated file paths (optional)
  status      String   @default("draft") // draft | reviewed | mastered
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// Academic deadlines — assignments, exams, mooting, presentations
model AcademicDeadline {
  id          String   @id @default(cuid())
  courseId    String?
  title       String   // "تسليم بحث العقود"
  type        String   // assignment | exam | mooting | presentation | registration
  dueDate     DateTime
  status      String   @default("todo") // todo | in_progress | submitted | done
  priority    String   @default("normal") // low | normal | high | urgent
  weight      Float?   // % of final grade
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
}

// Legal terms bank — vocabulary student collects
model LegalTerm {
  id          String   @id @default(cuid())
  term        String   @unique
  definition  String
  category    String   @default("general") // general | civil | criminal | commercial | administrative | constitutional | procedural | family
  origin      String?  // source law/system (e.g. "القانون المدني السعودي")
  example     String?  // usage example
  mastery     String   @default("learning") // learning | familiar | mastered
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Casebook — judicial principles, precedents, landmark cases
model CaseEntry {
  id            String   @id @default(cuid())
  caseName      String   // "قضية الدوسري ضد شركة..."
  citation      String?  // reference number / year
  court         String?  // "محكمة الاستئناف بالرياض"
  principle     String   // the legal principle established
  subject       String   // category (civil | criminal | ...)
  summary       String?  // brief facts + holding
  significance  String?  // why this case matters (for study)
  rating        Int      @default(3) // 1-5 importance
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
