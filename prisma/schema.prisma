// Sanad — operational legal/SME dashboard
// Persistent data lives here. UI prefs, timer state, and daily todos
// live in localStorage to keep the home server load minimal.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("lawyer") // lawyer | sme_owner | hr | freelancer | student
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== Client management (CRM) =====
model Client {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("individual") // individual | corporate
  phone       String?
  email       String?
  nationalId  String?  // هوية وطنية أو سجل تجاري
  address     String?
  company     String?  // company name if corporate
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases         LegalCase[]
  documents     LegalDocument[]
  communications Communication[]
  invoices      Invoice[]
}

// Compliance Tracker — Iqama, CR, employee contracts, licenses
model ComplianceItem {
  id          String   @id @default(cuid())
  title       String
  category    String   // iqama | cr | contract | license | tax | gosi
  entityName  String   // employee name, company name, etc.
  issueDate   DateTime
  expiryDate  DateTime
  status      String   @default("active") // active | expiring | expired | renewed
  notes       String?
  notifyDays  Int      @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Case Kanban — Drafting / Client Review / Filed / Closed
model LegalCase {
  id          String   @id @default(cuid())
  title       String
  clientId    String?
  clientName  String   // kept for backwards compat / display
  caseType    String   // litigation | contract | consultation | ip | corporate
  stage       String   @default("drafting") // drafting | client_review | filed | closed
  priority    String   @default("normal") // low | normal | high | urgent
  dueDate     DateTime?
  hearingDate DateTime? // next court hearing
  value       Float?   // estimated value / billing amount
  caseNumber  String?  // رقم القضية في المحكمة
  court       String?  // المحكمة
  opposingParty String? // الخصم
  notes       String?
  portalToken String?  @unique // رابط البوابة السري للعميل
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client        Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  timeEntries   TimeEntry[]
  communications Communication[]
  invoices      Invoice[]
}

// Document Lifecycle
model LegalDocument {
  id           String   @id @default(cuid())
  title        String
  docType      String   // nda | employment | non_compete | msa | subcontract | policy | pleading | contract_draft | court_filing
  status       String   @default("draft") // draft | sent | active | expiring | expired
  parties      String
  signedDate   DateTime?
  expiryDate   DateTime?
  caseId       String?
  clientId     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

// Tasks — manual and auto-generated from doc lifecycle events
model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?
  status       String   @default("todo") // todo | in_progress | done
  priority     String   @default("normal") // low | normal | high
  dueDate      DateTime?
  relatedDoc   String?  // doc title if auto-generated
  caseId       String?
  autoGen      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Billable hours + focus sessions
model TimeEntry {
  id           String   @id @default(cuid())
  caseId       String?
  description  String
  durationSec  Int
  billable     Boolean  @default(false)
  hourlyRate   Float?
  invoiced     Boolean  @default(false) // true once attached to an invoice
  invoiceId    String?  // link to invoice
  sessionType  String   @default("focus") // focus | billable | meeting | break
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  case         LegalCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)
  invoice      Invoice?   @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
}

// Daily Brief — micro feed of MoJ/MHRSD updates
model DailyBrief {
  id          String   @id @default(cuid())
  title       String
  summary     String
  source      String   // MoJ | MHRSD | VAT | local_tip
  category    String   // regulation | labor | tax | corporate | ip
  url         String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ===== Invoicing =====
model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique // INV-2026-001
  clientId    String?
  caseId      String?
  issueDate   DateTime @default(now())
  dueDate     DateTime?
  status      String   @default("draft") // draft | sent | paid | overdue | cancelled
  subtotal    Float    @default(0)
  vatRate     Float    @default(15) // Saudi VAT
  vatAmount   Float    @default(0)
  total       Float    @default(0)
  paidAmount  Float    @default(0)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  case        LegalCase?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]
}

// ===== Communications log =====
model Communication {
  id          String   @id @default(cuid())
  clientId    String?
  caseId      String?
  type        String   // call | email | meeting | sms | note
  direction   String   @default("outgoing") // incoming | outgoing
  subject     String
  body        String
  durationMin Int?     // for calls/meetings
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  case        LegalCase?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
}

// ===== Student mode tables =====

model Course {
  id          String   @id @default(cuid())
  title       String
  code        String?
  instructor  String?
  semester    String?
  credits     Int?
  color       String   @default("#0F5132")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lectures    Lecture[]
  deadlines   AcademicDeadline[]
}

model Lecture {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  lectureDate DateTime
  topic       String?
  notes       String
  attachments String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model AcademicDeadline {
  id          String   @id @default(cuid())
  courseId    String?
  title       String
  type        String
  dueDate     DateTime
  status      String   @default("todo")
  priority    String   @default("normal")
  weight      Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
}

model LegalTerm {
  id          String   @id @default(cuid())
  term        String   @unique
  definition  String
  category    String   @default("general")
  origin      String?
  example     String?
  mastery     String   @default("learning")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CaseEntry {
  id            String   @id @default(cuid())
  caseName      String
  citation      String?
  court         String?
  principle     String
  subject       String
  summary       String?
  significance  String?
  rating        Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReviewSession {
  id           String   @id @default(cuid())
  mode         String
  sourceType   String
  sourceLabel  String
  cardCount    Int
  correctCount Int      @default(0)
  reviewedCount Int     @default(0)
  durationSec  Int      @default(0)
  score        Float?
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
}
